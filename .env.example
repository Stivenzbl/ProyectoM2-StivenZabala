# ============================================================
# Variables de entorno - EJEMPLO (no subir el .env real con credenciales)
# ============================================================

# Puerto donde escucha la API
PORT=3000

# --- Conexión local ( PostgreSQL en tu máquina ) ---
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=miniblog_db
PG_USER=postgres
PG_PASSWORD=postgres

# --- En Railway ---
# Railway inyecta DATABASE_URL automáticamente al enlazar el plugin de
# PostgreSQL con el servicio web (valor: ${{Postgres.DATABASE_URL}}).
# La app PRIORIZA esta variable sobre las PG_* y habilita SSL sola.
# No hace falta copiarla aquí; queda como referencia:
# DATABASE_URL=postgresql://postgres:***@***.railway.internal:5432/railway

# Tuning del pool de conexiones (opcional)
DB_MAX_CONNECT=10
DB_IDLETIMEOUT=10000
DB_CONNECTIONTIMEOUT=5000
